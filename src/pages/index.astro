---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ohdsLogo from '../assets/onehealth-dataspace-symbol.png';
import cesgaLogo from '../assets/cesga-logo.png';
---

<Layout>
	<main class="max-w-5xl mx-auto px-6 py-12 space-y-20">
		<!-- Header / Logos -->
		<header class="flex flex-col sm:flex-row items-center justify-between gap-8 border-b-4 border-black pb-8">
			<div class="flex items-center gap-6">
				<a href="https://dataspace.cesga.es/" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
					<Image src={ohdsLogo} alt="OneHealth DataSpace Logo" class="h-16 w-auto" />
				</a>
				<div class="text-4xl font-black leading-none">x</div>
				<a href="https://cesga.es/" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
					<Image src={cesgaLogo} alt="CESGA Logo" class="h-16 w-auto" />
				</a>
			</div>
			<div class="text-right">
				<p class="font-bold text-xl uppercase text-accent">9 Junio 2026</p>
				<p class="text-sm">SANTIAGO DE COMPOSTELA, ESPAÑA</p>
			</div>
		</header>

		<!-- Hero Section -->
		<section class="space-y-4">
			<h1 class="text-6xl sm:text-8xl md:text-9xl leading-[0.8] tracking-tighter">
				Evento final
			</h1>
			<p class="text-xl max-w-3xl font-bold uppercase border-l-8 border-accent pl-4 py-2">
				Una tarde de debate abierto sobre la IA que queremos: <br> sus valores, sus límites y lo que construimos alrededor.
			</p>
		</section>	

		<!-- Info Grid -->
		<section class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="brutalist-card space-y-4">
				<h2 class="text-2xl border-b-2 border-black pb-2">Detalles</h2>
				<ul class="space-y-2 font-bold uppercase">
					<li>📅 Martes 9 de Junio</li>
					<li>⏰ 10:00 - 14:00</li>
					<li>📍 Rúa anonima, 10(CESGA)</li>
					<li>👥 Aforo limitado: 100 personas</li>
				</ul>
			</div>
			<div class="brutalist-card space-y-4">
				<h2 class="text-2xl border-b-2 border-black pb-2">Participación Directa</h2>
				<p class="text-sm font-bold">
					Una oportunidad para preguntar, debatir y obtener respuestas directas sobre o entorno onehealth.
					<br></br>
					Contaremos con la participación de perfiles do <span class="text-accent">OneHealth DataSpace</span>.
				</p>
			</div>
		</section>

		<!-- Steps -->
		<section class="space-y-8">
			<h2 class="text-4xl text-center">¿Cómo funciona?</h2>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">01</div>
					<h3 class="text-xl mb-2">Reuniones</h3>
					<p class="text-xs uppercase font-bold">Propondremos <span class="text-accent">temas</span> al inicio sobre distintos ámbitos del onehealth.</p>
				</div>
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">02</div>
					<h3 class="text-xl mb-2">Debates</h3>
					<p class="text-xs uppercase font-bold">Se harán debates sobre diferentes temáticas</p>
				</div>
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">03</div>
					<h3 class="text-xl mb-2">Preguntas</h3>
					<p class="text-xs uppercase font-bold">Se dará espacio a preguntas.</p>
				</div>
			</div>
		</section>

		<!-- Reservation Section -->
		<section id="rsvp" class="space-y-6 pt-12 border-t-4 border-black">
			<h2 class="text-4xl text-center">Reserva tu plaza</h2>
		</section>

		<footer class="flex flex-wrap justify-between gap-2 text-xs opacity-50 uppercase py-12 border-t-4 border-black">
			<p>OneHealth DataSpace x CESGA</p>
			<p>2026 — <a href="https://www.cesga.es" class="underline hover:opacity-100 transition-opacity">CESGA</a></p>
		</footer>
	</main>
</Layout>
