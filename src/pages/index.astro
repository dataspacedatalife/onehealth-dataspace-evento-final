---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ohdsLogo from '../assets/onehealth-dataspace-symbol.png';
import cesgaLogo from '../assets/cesga-logo.png';
---

<Layout>
	<main class="max-w-5xl mx-auto px-6 py-12 space-y-20">
		<!-- Header / Logos -->
		<header class="flex flex-col sm:flex-row items-center justify-between gap-8 border-b-4 border-black pb-8">
			<div class="flex items-center gap-6">
				<a href="https://dataspace.cesga.es/" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
					<Image src={ohdsLogo} alt="OneHealth DataSpace Logo" class="h-16 w-auto" />
				</a>
				<div class="text-4xl font-black leading-none">x</div>
				<a href="https://cesga.es/" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity">
					<Image src={cesgaLogo} alt="CESGA Logo" class="h-16 w-auto" />
				</a>
			</div>
			<div class="text-right">
				<p class="font-bold text-xl uppercase text-accent">17 Junio 2026</p>
				<p class="text-sm">SANTIAGO DE COMPOSTELA, ESPAÑA</p>
			</div>
		</header>

		<!-- Hero Section -->
		<section class="space-y-4">
			<h1 class="text-4xl sm:text-6xl md:text-7xl leading-[0.8] tracking-tighter">
				Evento final
			</h1>
			<h1 class="text-4xl md:text-5xl max-w-5xl border-l-8 border-accent pl-4 py-2 text-accent">
				OneHealth DataSpace presenta resultados y abre camino a la 1HealthAI Factory
			</h1>

		</section>	

		<!-- Info Grid -->
		<section class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="brutalist-card space-y-4">
				<h2 class="text-2xl border-b-2 border-black pb-2">El evento</h2>
				<p class="space-y-4 text-m font-bold">El evento final del próximo 17 de junio del proyecto OneHealth DataSpace en Santiago de Compostela permitirá presentar los principales resultados alcanzados por el proyecto, compartir la evolución de los casos de uso participantes y abordar el papel de OneHealth DataSpace como antesala de la futura 1HealthAI Factory.</p>
			</div>
			<div class="brutalist-card space-y-4">
			<h2 class="text-2xl border-b-2 border-black pb-2">Programa</h2>

			<div class="space-y-4 text-sm font-bold">
				<p>
					<span class="text-accent">10:00h.</span> Apertura institucional. Intervienen:
					María Luz Couce Pico, Directora Científica del IDIS; Carmen Cotelo Queijo,
					Directora de GAIN; Lois Orosa Nogueira, Director Científico del CESGA;
					Representante del Ministerio de Transformación Digital y de la Función Pública.
				</p>

				<p>
					<span class="text-accent">10:30h.</span> Avance de resultados de la Política de
					Impulso a Espacios de Datos en España.
				</p>

				<p>
					<span class="text-accent">10:45h.</span> Resultados del proyecto.
				</p>

				<p>
					<span class="text-accent">11:30h.</span> Pausa café.
				</p>

				<p>
					<span class="text-accent">12:00h.</span> Rueda de presentación de casos de uso
					participantes.
				</p>

				<p>
					<span class="text-accent">13:15h.</span> OneHealth DataSpace, antesala de la
					1HealthAI Factory. Interviene: Javier Cacheiro López, Director Científico de
					OneHealth DataSpace del CESGA.
				</p>
			</div>
		</div>
		</section>
		<!-- Registration Section -->
		<section id="rsvp" class="space-y-6 pt-12 pb-12 border-t-4 border-black border-b-4">
			<h2 class="text-5xl text-center">
			Inscríbete
			<a
				href="https://www.cesga.es/evento_de_cierre_onehealth_dataspace/"
				target="_blank"
				rel="noopener noreferrer"
				class="underline text-accent font-bold hover:opacity-70 transition-opacity"
			>
				aquí
			</a>
			!
			</h2>
		</section>
		<!-- Important details -->
		<section class="space-y-8">
			<h2 class="text-4xl text-center">Dónde y cuándo</h2>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">📅</div>
					<p class="text-xl font-black uppercase text-b mb-2"> Miércoles 17 de Junio, <br> de 09:30h – 13:00h</p>
				</div>
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">🏢</div>
					<p class="text-xl font-black uppercase text-b mb-2"> Salón de actos del Hospital Clínico Universitario de Santiago</p>
				</div>
				<div class="brutalist-card text-center hover:bg-yellow-100 transition-colors">
					<div class="text-4xl font-black mb-4">👥</div>
					<p class="text-xl font-black uppercase text-b mb-2">Plazas limitadas</p>
				</div>
			</div>
		</section>

		

		<footer class="flex flex-wrap justify-between gap-2 text-xs opacity-50 uppercase py-12 border-t-4 border-black">
			<p>OneHealth DataSpace x CESGA</p>
			<p>2026 — <a href="https://www.cesga.es" class="underline hover:opacity-100 transition-opacity">CESGA</a></p>
		</footer>
	</main>
</Layout>
